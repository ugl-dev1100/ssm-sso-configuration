#!/usr/bin/env bash

set -euo pipefail

HOST="127.0.0.1"

echo "🔍 Checking UAT Ports..."
for port in {5001..5018}; do
  if nc -z "$HOST" "$port" >/dev/null 2>&1; then
    echo "✅ UAT Port $port is OPEN"
  else
    echo "❌ UAT Port $port is CLOSED"
  fi
done

echo ""
echo "🔍 Checking PROD Ports..."
for port in {6001..6003}; do
  if nc -z "$HOST" "$port" >/dev/null 2>&1; then
    echo "✅ PROD Port $port is OPEN"
  else
    echo "❌ PROD Port $port is CLOSED"
  fi
done

echo ""
echo "----------------------------------------"
echo "✅ Port check completed"