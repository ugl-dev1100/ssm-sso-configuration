#!/usr/bin/env bash

set -euo pipefail

PROFILE="${1:-}"
MAP_FILE="$HOME/.rds-map"

[ -z "$PROFILE" ] && { echo "Usage: rds-instances <uat|prod>"; exit 1; }
[ ! -f "$MAP_FILE" ] && { echo "❌ Mapping file not found (~/.rds-map)"; exit 1; }

REGION=$(aws configure get region --profile "$PROFILE")
REGION=${REGION:-us-east-1}

# Ensure SSO login
aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1 || \
aws sso login --profile "$PROFILE"

# -----------------------------
# Find Jumphost
# -----------------------------
JUMP=$(aws ec2 describe-instances \
  --profile "$PROFILE" \
  --region "$REGION" \
  --filters "Name=instance-state-name,Values=running" \
  --query "Reservations[].Instances[?contains(Tags[?Key=='Name'].Value | [0], 'Jumphost')].InstanceId" \
  --output text | head -n 1)

[ -z "$JUMP" ] && { echo "❌ No Jumphost found"; exit 1; }

echo "Using Jumphost: $JUMP"
echo "Starting DB tunnels ($PROFILE)..."

CURRENT_ENV=""

# -----------------------------
# FUNCTIONS
# -----------------------------

# Universal port check (Mac + Linux + WSL)
is_port_active() {
  lsof -iTCP:"$1" -sTCP:LISTEN >/dev/null 2>&1
}

# Kill stale process on port
kill_port() {
  local PORT=$1
  PIDS=$(lsof -tiTCP:"$PORT" 2>/dev/null || true)

  if [ -n "$PIDS" ]; then
    echo "⚠️ Cleaning stale process on port $PORT"
    echo "$PIDS" | xargs kill -9
  fi
}

# Start SSM tunnel safely
start_tunnel() {
  local DB=$1
  local PORT=$2
  local ENDPOINT=$3

  echo "🚀 Starting: $DB → 127.0.0.1:$PORT"

  # Clean any stale process
  kill_port "$PORT"

  # Start tunnel using nohup (important)
  nohup aws ssm start-session \
    --target "$JUMP" \
    --profile "$PROFILE" \
    --region "$REGION" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "{\"host\":[\"$ENDPOINT\"],\"portNumber\":[\"3306\"],\"localPortNumber\":[\"$PORT\"]}" \
    >"/tmp/ssm-$PORT.log" 2>&1 &

  # Wait until port is active
  for i in {1..10}; do
    if is_port_active "$PORT"; then
      echo "✅ Tunnel ready: $DB ($PORT)"
      return 0
    fi
    sleep 1
  done

  echo "❌ Tunnel failed: $DB ($PORT)"
  echo "👉 Check log: /tmp/ssm-$PORT.log"
  return 1
}

# -----------------------------
# PROCESS MAP FILE
# -----------------------------
while IFS="=" read -r DB PORT; do

  DB=$(echo "$DB" | tr -d '\r' | xargs)
  PORT=$(echo "$PORT" | tr -d '\r' | xargs)

  [[ -z "$DB" ]] && continue

  case "$DB" in
    "[uat_databases]") CURRENT_ENV="uat"; continue ;;
    "[prod_databases]") CURRENT_ENV="prod"; continue ;;
  esac

  [[ "$DB" =~ ^# ]] && continue
  [[ "$CURRENT_ENV" != "$PROFILE" ]] && continue

  if is_port_active "$PORT"; then
    echo "✅ $DB already active on $PORT"
    continue
  fi

  ENDPOINT=$(aws rds describe-db-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --db-instance-identifier "$DB" \
    --query "DBInstances[0].Endpoint.Address" \
    --output text)

  start_tunnel "$DB" "$PORT" "$ENDPOINT" &

done < "$MAP_FILE"

wait

# -----------------------------
# OUTPUT
# -----------------------------
echo "----------------------------------------"
echo "✅ All tunnels processed for profile: $PROFILE"


echo "👉 Connect from Windows (DBeaver) / Mac:"
echo "Host: 127.0.0.1/localhost"

echo "----------------------------------------"

# Show active tunnels
echo "Active tunnels:"
lsof -iTCP -sTCP:LISTEN | grep session-manager-plugin || echo "None"

echo ""
echo "🔍 Verify:"
echo "lsof -iTCP:<port> -sTCP:LISTEN"
echo "nc -zv 127.0.0.1 <port>"