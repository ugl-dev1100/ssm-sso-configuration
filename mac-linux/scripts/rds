#!/usr/bin/env bash

set -euo pipefail

PROFILE="${1:-}"
MAP_FILE="$HOME/.rds-map"

[ -z "$PROFILE" ] && { echo "Usage: rds-instances <uat|prod>"; exit 1; }
[ ! -f "$MAP_FILE" ] && { echo "❌ Mapping file not found (~/.rds-map)"; exit 1; }

REGION=$(aws configure get region --profile "$PROFILE")
REGION=${REGION:-us-east-1}

# Ensure SSO login
aws sts get-caller-identity --profile "$PROFILE" >/dev/null 2>&1 || \
aws sso login --profile "$PROFILE"

# -----------------------------
# Find Jumphost
# -----------------------------
JUMP=$(aws ec2 describe-instances \
  --profile "$PROFILE" \
  --region "$REGION" \
  --filters "Name=instance-state-name,Values=running" \
  --query "Reservations[].Instances[?contains(join('', Tags[?Key=='Name'].Value), 'Jumphost')].InstanceId"\
  --output text | head -n 1)

[ -z "$JUMP" ] && { echo "❌ No Jumphost found"; exit 1; }

echo "Using Jumphost: $JUMP"
echo "Starting DB tunnels ($PROFILE)..."

CURRENT_ENV=""

# -----------------------------
# FUNCTIONS
# -----------------------------

is_port_active() {
  nc -z 127.0.0.1 "$1" >/dev/null 2>&1
}

kill_port() {
  lsof -tiTCP:"$1" 2>/dev/null | xargs kill -9 2>/dev/null || true
}

start_tunnel() {
  local DB=$1
  local PORT=$2
  local ENDPOINT=$3

  if is_port_active "$PORT"; then
    echo "✅ $DB already active on $PORT"
    return
  fi

  echo "🚀 Starting: $DB → 127.0.0.1:$PORT"

  kill_port "$PORT"

  aws ssm start-session \
    --target "$JUMP" \
    --profile "$PROFILE" \
    --region "$REGION" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "{\"host\":[\"$ENDPOINT\"],\"portNumber\":[\"3306\"],\"localPortNumber\":[\"$PORT\"]}" \
    > /tmp/ssm-$PORT.log 2>&1 &

  # Just mark it started (no wait)
  echo "⏳ Tunnel launching: $DB ($PORT)"
}

# -----------------------------
# PROCESS MAP FILE
# -----------------------------
while IFS="=" read -r DB PORT || [ -n "$DB" ]; do

  DB=$(echo "$DB" | tr -d '\r' | xargs)
  PORT=$(echo "$PORT" | tr -d '\r' | xargs)

  [[ -z "$DB" ]] && continue

  case "$DB" in
    "[uat_databases]") CURRENT_ENV="uat"; continue ;;
    "[prod_databases]") CURRENT_ENV="prod"; continue ;;
  esac

  [[ "$DB" =~ ^# ]] && continue
  [[ "$CURRENT_ENV" != "$PROFILE" ]] && continue

  ENDPOINT=$(aws rds describe-db-instances \
    --profile "$PROFILE" \
    --region "$REGION" \
    --db-instance-identifier "$DB" \
    --query "DBInstances[0].Endpoint.Address" \
    --output text)

  start_tunnel "$DB" "$PORT" "$ENDPOINT"

done < "$MAP_FILE"

# -----------------------------
# OUTPUT
# -----------------------------
echo "----------------------------------------"
echo "✅ All tunnels processed for profile: $PROFILE"
echo "👉 Connect using:"
echo "Host: 127.0.0.1"
echo "----------------------------------------"

# echo "Active tunnels:"
# while IFS="=" read -r DB PORT; do
#   PORT=$(echo "$PORT" | xargs)

#   if is_port_active "$PORT"; then
#     echo "✅ Port $PORT ACTIVE"
#   fi
# done < "$MAP_FILE"

echo ""
echo "🔍 Verify:"
echo "nc -zv localhost <port>"